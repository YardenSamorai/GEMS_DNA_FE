GENERATE_SOURCEMAP=false
REACT_APP_API_URL=
REACT_APP_PUBLISHABLE_KEY=
REACT_APP_ENCRYPT_SECRET=

# iJewel3D Drive workspace (optional). When set, the 3D Preview tab uses
# this as the default `instance` so users only need to paste a File ID per
# jewelry item. Per-item override lives on the jewelry_items row itself.
# Example: drive
REACT_APP_IJEWEL_INSTANCE=
